---
import { t, type Locale } from '../i18n/ui';

interface StudyMove {
  id: string;
  ply: number;
  san: string;
  nl: string;
  fenAfter: string;
  variant: string;
  parent: string | null;
}

interface StudyData {
  number: number;
  source?: string;
  gbr: string;
  fen: string;
  stipulation: '+' | '=';
  moves: StudyMove[];
}

interface Props {
  study: StudyData;
  locale: Locale;
}

const { study, locale } = Astro.props;
const boardId = `board-${study.number}`;

// Group plies into (number, white?, black?) rows the way a chess book does.
function rowify(moves: StudyMove[]): Array<{ num: number; white?: StudyMove; black?: StudyMove }> {
  const rows = new Map<number, { num: number; white?: StudyMove; black?: StudyMove }>();
  for (const m of [...moves].sort((a, b) => a.ply - b.ply)) {
    const num = Math.floor((m.ply + 1) / 2);
    const row = rows.get(num) ?? { num };
    if (m.ply % 2 === 1) row.white = m; else row.black = m;
    rows.set(num, row);
  }
  return [...rows.values()].sort((a, b) => a.num - b.num);
}

const mainRows = rowify(study.moves.filter((m) => m.variant === 'main'));

// Two-level variant hierarchy. Top-level variants (single-letter labels like
// "A", "B") become their own sections; their sub-variants ("main.a", "B.c")
// are nested as labelled rows inside. A sub-variant under "main" is a
// sibling of Variant A/B — they all branch from the main line.
interface VariantSection {
  id: string;
  label: string;
  rows: ReturnType<typeof rowify>;
  children: { label: string; rows: ReturnType<typeof rowify> }[];
}

const sections: VariantSection[] = [];
const seenIds = new Set<string>();
for (const m of study.moves) {
  if (m.variant === 'main') continue;
  if (seenIds.has(m.variant)) continue;
  seenIds.add(m.variant);

  const vid = m.variant;
  const parts = vid.split('.');
  if (parts.length === 1) {
    // Top-level variant like "A" / "B"
    sections.push({
      id: vid,
      label: `Variant ${vid}`,
      rows: rowify(study.moves.filter((x) => x.variant === vid)),
      children: [],
    });
  } else {
    // Sub-variant "A.a" / "main.b" — attach to parent if present, else render as a top-level "section".
    const parentId = parts.slice(0, -1).join('.');
    const sublabel = `${parts[parts.length - 1]})`;
    const parent = sections.find((s) => s.id === parentId);
    if (parent) {
      parent.children.push({
        label: sublabel,
        rows: rowify(study.moves.filter((x) => x.variant === vid)),
      });
    } else {
      sections.push({
        id: vid,
        label: sublabel,
        rows: rowify(study.moves.filter((x) => x.variant === vid)),
        children: [],
      });
    }
  }
}
---

<div class="study-board" data-board-id={boardId} data-study={JSON.stringify(study)}>
  <div class="board-frame">
    <div id={boardId} class="board"></div>
    <div class="board-controls" role="group" aria-label={t(locale, 'study.moves')}>
      <button type="button" data-nav="start" aria-label={t(locale, 'board.start')}>⏮</button>
      <button type="button" data-nav="prev" aria-label={t(locale, 'board.prev')}>◀</button>
      <button type="button" data-nav="next" aria-label={t(locale, 'board.next')}>▶</button>
      <button type="button" data-nav="end" aria-label={t(locale, 'board.end')}>⏭</button>
    </div>
  </div>

  <div class="moves-panel">
    {study.source && (
      <p class="source">
        <em>{study.source}</em>
      </p>
    )}
    <p class="gbr">
      <span class="stipulation">{study.stipulation}</span>
      <span>{study.gbr}</span>
    </p>

    <section class="main-line">
      <h3 class="sr-only">{t(locale, 'study.moves')}</h3>
      <table class="move-table">
        <tbody>
          {mainRows.map((r) => (
            <tr>
              <td class="num">{r.num}.</td>
              <td class="w">
                {r.white && (
                  <button type="button" data-move={r.white.id} class="move" title={r.white.san}>
                    {r.white.nl}
                  </button>
                )}
              </td>
              <td class="b">
                {r.black && (
                  <button type="button" data-move={r.black.id} class="move" title={r.black.san}>
                    {r.black.nl}
                  </button>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    {sections.length > 0 && (
      <section class="variants">
        <h3>{t(locale, 'study.variants')}</h3>
        {sections.map((sec) => (
          <details open class="variant-section">
            <summary>{sec.label}</summary>
            <table class="move-table">
              <tbody>
                {sec.rows.map((r) => (
                  <tr>
                    <td class="num">{r.num}{r.white ? '.' : '…'}</td>
                    <td class="w">
                      {r.white && (
                        <button type="button" data-move={r.white.id} class="move" title={r.white.san}>
                          {r.white.nl}
                        </button>
                      )}
                    </td>
                    <td class="b">
                      {r.black && (
                        <button type="button" data-move={r.black.id} class="move" title={r.black.san}>
                          {r.black.nl}
                        </button>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
            {sec.children.map((child) => (
              <div class="sub-variant">
                <span class="sub-label">{child.label}</span>
                <table class="move-table">
                  <tbody>
                    {child.rows.map((r) => (
                      <tr>
                        <td class="num">{r.num}{r.white ? '.' : '…'}</td>
                        <td class="w">
                          {r.white && (
                            <button type="button" data-move={r.white.id} class="move" title={r.white.san}>
                              {r.white.nl}
                            </button>
                          )}
                        </td>
                        <td class="b">
                          {r.black && (
                            <button type="button" data-move={r.black.id} class="move" title={r.black.san}>
                              {r.black.nl}
                            </button>
                          )}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ))}
          </details>
        ))}
      </section>
    )}
  </div>
</div>

<script>
  import { initStudyBoard } from './study-board.client.ts';
  document.querySelectorAll<HTMLElement>('.study-board').forEach((el) => initStudyBoard(el));
</script>

<style>
  .study-board {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin: 2rem 0;
  }

  @media (min-width: 900px) {
    .study-board {
      grid-template-columns: 420px 1fr;
      align-items: start;
    }
    .board-frame {
      position: sticky;
      top: 1rem;
    }
  }

  .board {
    aspect-ratio: 1;
    max-width: 420px;
    width: 100%;
  }

  .board-controls {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    justify-content: center;
  }

  .board-controls button {
    font-size: 1.25rem;
    padding: 0.25rem 0.75rem;
    border: 1px solid theme('colors.ink.muted' / 50%);
    background: theme('colors.paper.light');
    border-radius: 4px;
    cursor: pointer;
  }
  .board-controls button:hover {
    background: theme('colors.paper.DEFAULT');
  }

  .moves-panel .source {
    margin: 0 0 0.25rem;
    color: theme('colors.ink.muted');
  }
  .moves-panel .gbr {
    font-family: monospace;
    margin: 0 0 1rem;
    color: theme('colors.ink.muted');
    font-size: 0.9rem;
  }
  .stipulation {
    font-weight: 700;
    margin-right: 0.5em;
    font-family: theme('fontFamily.serif');
    color: theme('colors.ink.DEFAULT');
  }

  .move-table {
    font-family: monospace;
    font-size: 0.95rem;
    border-collapse: collapse;
    margin: 0.25rem 0;
  }
  .move-table td {
    padding: 0.1rem 0.5rem 0.1rem 0;
    vertical-align: baseline;
    white-space: nowrap;
  }
  .move-table td.num {
    color: theme('colors.ink.muted');
    text-align: right;
    padding-right: 0.5rem;
    width: 2.5rem;
  }
  .move-table td.w, .move-table td.b {
    min-width: 5rem;
  }
  .sub-variant {
    display: flex;
    align-items: flex-start;
    margin-left: 1rem;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }
  .sub-variant .sub-label {
    font-family: theme('fontFamily.serif');
    font-style: italic;
    color: theme('colors.ink.muted');
    padding-top: 0.15rem;
  }
  .move {
    background: transparent;
    border: none;
    padding: 0 2px;
    cursor: pointer;
    color: inherit;
    font: inherit;
    border-radius: 2px;
  }
  .move:hover {
    background: rgba(122, 31, 14, 0.12);
  }
  .move.active {
    background: rgba(122, 31, 14, 0.22);
    outline: 1px solid rgba(122, 31, 14, 0.45);
  }

  .variants {
    margin-top: 1.25rem;
  }
  .variants h3 {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: theme('colors.ink.muted');
    margin: 0 0 0.5rem;
  }
  .variants details {
    margin-bottom: 0.5rem;
  }
  .variants summary {
    cursor: pointer;
    font-weight: 600;
    padding: 0.25rem 0;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>
